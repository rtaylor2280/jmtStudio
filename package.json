{
  "name": "jmt-studio",
  "version": "1.0.0",
  "description": "ProffieOS Configuration Tool by Jedi Master Tech",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "postinstall": "node scripts/copy-monaco.js"
  },
  "build": {
    "appId": "com.jmt.proffieos-editor",
    "productName": "JMT Studio",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "toolchain.js",
      "portDetector.js",
      "proffieos.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      { "from": "resources/", "to": ".", "filter": ["**/*"] }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "monaco-editor": "0.44.0"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
