{
  "name": "jmt-studio",
  "version": "1.6.0",
  "description": "ProffieOS Configuration Tool by Jedi Master Tech",
  "author": "Jedi Master Tech",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "postinstall": "node scripts/copy-monaco.js"
  },
  "build": {
    "appId": "com.jmt.proffieos-editor",
    "productName": "JMT Studio",
    "npmRebuild": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JMT Studio",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "files": [
      "main.js",
      "preload.js",
      "toolchain.js",
      "portDetector.js",
      "proffieos.js",
      "cacheManager.js",
      "renderer/**/*",
      "assets/**/*",
      "LICENSE.txt"
    ],
    "extraResources": [
      {
        "from": "resources/",
        "to": ".",
        "filter": [
          "arduino-cli/**/*",
          "tools/**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3",
    "monaco-editor": "0.44.0",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
